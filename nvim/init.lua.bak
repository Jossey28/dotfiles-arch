-- ==========================================
-- Basic Editor Settings (Options)
-- ==========================================
vim.opt.number = true
vim.opt.relativenumber = true
vim.opt.expandtab = true
vim.opt.shiftwidth = 2
vim.opt.tabstop = 2
vim.opt.smartindent = true
vim.opt.ignorecase = true
vim.opt.smartcase = true
vim.opt.clipboard = "unnamedplus"

-- ==========================================
-- Keymaps
-- ==========================================
-- Set space as the leader key
vim.g.mapleader = " "
vim.g.maplocalleader = " "

-- Quick save and quit
vim.keymap.set("n", "<leader>w", ":w<CR>", { desc = "Save file" })
vim.keymap.set("n", "<leader>q", ":q<CR>", { desc = "Quit" })

-- ==========================================
-- Plugin Manager (lazy.nvim Bootstrap)
-- ==========================================
local lazypath = vim.fn.stdpath("data") .. "/lazy/lazy.nvim"
if not (vim.uv or vim.loop).fs_stat(lazypath) then
  local lazyrepo = "https://github.com/folke/lazy.nvim.git"
  local out = vim.fn.system({ "git", "clone", "--filter=blob:none", "--branch=stable", lazyrepo, lazypath })
  if vim.v.shell_error ~= 0 then
    vim.api.nvim_echo({
      { "Failed to clone lazy.nvim:\n", "ErrorMsg" },
      { out, "WarningMsg" },
      { "\nPress any key to exit..." },
    }, true, {})
    vim.fn.getchar()
    os.exit(1)
  end
end
vim.opt.rtp:prepend(lazypath)

-- Initialize plugins (add your plugins inside the array)
require("lazy").setup({
  -- Example: A colorscheme
  -- {
    --   "folke/tokyonight.nvim",
    --   lazy = false,
    --   priority = 1000,
    --   config = function()
      --     vim.cmd([[colorscheme tokyonight]])
      --   end,
      -- },

    -- Example: Treesitter for better syntax highlighting
    {
      "nvim-treesitter/nvim-treesitter",
      lazy = false, -- Treesitter must load on startup
      build = ":TSUpdate",
      opts = {
        -- Add languages you want to support
        ensure_installed = { "bash", "c", "lua", "python", "vim", "vimdoc", "javascript", "typescript" },
        auto_install = true,
        highlight = { enable = true },
        indent = { enable = true },
      },
      config = function(_, opts)
      end,
    },
  })

